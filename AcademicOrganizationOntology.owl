<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/ayna/ontologies/2026/AcademicOrganizationOntology#"
     xml:base="http://www.semanticweb.org/ayna/ontologies/2026/AcademicOrganizationOntology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/ayna/ontologies/2026/AcademicOrganizationOntology"/>

    <!-- Classes -->
    <owl:Class rdf:about="#AcademicOrganization"/>
    <owl:Class rdf:about="#University"><rdfs:subClassOf rdf:resource="#AcademicOrganization"/></owl:Class>
    <owl:Class rdf:about="#Department"><rdfs:subClassOf rdf:resource="#AcademicOrganization"/></owl:Class>
    <owl:Class rdf:about="#Faculty"><rdfs:subClassOf rdf:resource="#AcademicOrganization"/></owl:Class>
    <owl:Class rdf:about="#Person"/>
    <owl:Class rdf:about="#Student"><rdfs:subClassOf rdf:resource="#Person"/></owl:Class>
    <owl:Class rdf:about="#Professor"><rdfs:subClassOf rdf:resource="#Person"/></owl:Class>
    <owl:Class rdf:about="#Staff"><rdfs:subClassOf rdf:resource="#Person"/></owl:Class>
    <owl:Class rdf:about="#AcademicProgram"/>
    <owl:Class rdf:about="#BachelorProgram"><rdfs:subClassOf rdf:resource="#AcademicProgram"/></owl:Class>
    <owl:Class rdf:about="#MasterProgram"><rdfs:subClassOf rdf:resource="#AcademicProgram"/></owl:Class>
    <owl:Class rdf:about="#Course"/>
    <owl:Class rdf:about="#Exam"/>
    <owl:Class rdf:about="#Classroom"/>
    <owl:Class rdf:about="#Semester"/>
    <owl:Class rdf:about="#Library"/>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="#studiesAt"><rdfs:domain rdf:resource="#Student"/><rdfs:range rdf:resource="#University"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#enrolledIn"><rdfs:domain rdf:resource="#Student"/><rdfs:range rdf:resource="#Course"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#teaches"><rdfs:domain rdf:resource="#Professor"/><rdfs:range rdf:resource="#Course"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#belongsToDepartment"><rdfs:domain rdf:resource="#Person"/><rdfs:range rdf:resource="#Department"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#offersCourse"><rdfs:domain rdf:resource="#Department"/><rdfs:range rdf:resource="#Course"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasExam"><rdfs:domain rdf:resource="#Course"/><rdfs:range rdf:resource="#Exam"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#attendsClass"><rdfs:domain rdf:resource="#Student"/><rdfs:range rdf:resource="#Classroom"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#assignedClassroom"><rdfs:domain rdf:resource="#Course"/><rdfs:range rdf:resource="#Classroom"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#supervises"><rdfs:domain rdf:resource="#Professor"/><rdfs:range rdf:resource="#Student"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasSemester"><rdfs:domain rdf:resource="#Course"/><rdfs:range rdf:resource="#Semester"/></owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#usesLibrary"><rdfs:domain rdf:resource="#Student"/><rdfs:range rdf:resource="#Library"/></owl:ObjectProperty>

    <!-- Data Properties -->
    <owl:DatatypeProperty rdf:about="#studentName"><rdfs:domain rdf:resource="#Student"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#professorName"><rdfs:domain rdf:resource="#Professor"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#staffName"><rdfs:domain rdf:resource="#Staff"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#universityName"><rdfs:domain rdf:resource="#University"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#departmentName"><rdfs:domain rdf:resource="#Department"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#courseName"><rdfs:domain rdf:resource="#Course"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#courseCode"><rdfs:domain rdf:resource="#Course"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#credits"><rdfs:domain rdf:resource="#Course"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#examDate"><rdfs:domain rdf:resource="#Exam"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#classroomNumber"><rdfs:domain rdf:resource="#Classroom"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#semesterName"><rdfs:domain rdf:resource="#Semester"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#email"><rdfs:domain rdf:resource="#Person"/><rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/></owl:DatatypeProperty>

    <!-- Individuals -->
    <owl:NamedIndividual rdf:about="#UniversityOfVerona"><rdf:type rdf:resource="#University"/><universityName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">University of Verona</universityName></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#ComputerScienceDepartment"><rdf:type rdf:resource="#Department"/><departmentName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Department of Computer Science</departmentName><offersCourse rdf:resource="#KnowledgeRepresentation"/><offersCourse rdf:resource="#MachineLearning"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#MathematicsDepartment"><rdf:type rdf:resource="#Department"/><departmentName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Department of Mathematics</departmentName><offersCourse rdf:resource="#LinearAlgebra"/></owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Ali"><rdf:type rdf:resource="#Student"/><studentName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ali</studentName><email rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ali@example.com</email><studiesAt rdf:resource="#UniversityOfVerona"/><enrolledIn rdf:resource="#KnowledgeRepresentation"/><enrolledIn rdf:resource="#MachineLearning"/><attendsClass rdf:resource="#Room101"/><belongsToDepartment rdf:resource="#ComputerScienceDepartment"/><usesLibrary rdf:resource="#CentralLibrary"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Sara"><rdf:type rdf:resource="#Student"/><studentName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sara</studentName><email rdf:datatype="http://www.w3.org/2001/XMLSchema#string">sara@example.com</email><studiesAt rdf:resource="#UniversityOfVerona"/><enrolledIn rdf:resource="#LinearAlgebra"/><attendsClass rdf:resource="#Room202"/><belongsToDepartment rdf:resource="#MathematicsDepartment"/><usesLibrary rdf:resource="#CentralLibrary"/></owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#ProfAhmed"><rdf:type rdf:resource="#Professor"/><professorName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prof. Ahmed</professorName><email rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ahmed@example.com</email><teaches rdf:resource="#KnowledgeRepresentation"/><belongsToDepartment rdf:resource="#ComputerScienceDepartment"/><supervises rdf:resource="#Ali"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#ProfFatima"><rdf:type rdf:resource="#Professor"/><professorName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prof. Fatima</professorName><email rdf:datatype="http://www.w3.org/2001/XMLSchema#string">fatima@example.com</email><teaches rdf:resource="#LinearAlgebra"/><belongsToDepartment rdf:resource="#MathematicsDepartment"/><supervises rdf:resource="#Sara"/></owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#KnowledgeRepresentation"><rdf:type rdf:resource="#Course"/><courseName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Knowledge Representation</courseName><courseCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">KR101</courseCode><credits rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</credits><hasExam rdf:resource="#KRExam"/><assignedClassroom rdf:resource="#Room101"/><hasSemester rdf:resource="#FallSemester"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#MachineLearning"><rdf:type rdf:resource="#Course"/><courseName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Machine Learning</courseName><courseCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ML102</courseCode><credits rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</credits><hasExam rdf:resource="#MLExam"/><assignedClassroom rdf:resource="#Room101"/><hasSemester rdf:resource="#FallSemester"/></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#LinearAlgebra"><rdf:type rdf:resource="#Course"/><courseName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Linear Algebra</courseName><courseCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MATH201</courseCode><credits rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</credits><hasExam rdf:resource="#LAExam"/><assignedClassroom rdf:resource="#Room202"/><hasSemester rdf:resource="#SpringSemester"/></owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#KRExam"><rdf:type rdf:resource="#Exam"/><examDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-07-20T10:00:00</examDate></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#MLExam"><rdf:type rdf:resource="#Exam"/><examDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-07-22T10:00:00</examDate></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#LAExam"><rdf:type rdf:resource="#Exam"/><examDate rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-07-25T10:00:00</examDate></owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#Room101"><rdf:type rdf:resource="#Classroom"/><classroomNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Room 101</classroomNumber></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Room202"><rdf:type rdf:resource="#Classroom"/><classroomNumber rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Room 202</classroomNumber></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#FallSemester"><rdf:type rdf:resource="#Semester"/><semesterName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fall Semester</semesterName></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#SpringSemester"><rdf:type rdf:resource="#Semester"/><semesterName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Spring Semester</semesterName></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#CentralLibrary"><rdf:type rdf:resource="#Library"/></owl:NamedIndividual>
</rdf:RDF>
